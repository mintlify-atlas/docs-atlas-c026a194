  "keyFeatures": [
    "SQL Copilot — AI-powered SQL generation, fixing, and explanation grounded in real database schema",
    "Schema-aware autocomplete for tables, columns, functions, and aliases",
    "Multi-tab SQL editor with result sets, saved queries, and instant chart visualizations",
    "Database Chatbot — conversational AI for exploring tables and SQL queries",
    "ClickHouse Monitoring — real-time metrics, query latency trends (P50/P95), QPM tracking",
    "ClickHouse Privileges UI — user/role management without writing GRANT SQL",
    "Multi-database support: ClickHouse (deep), PostgreSQL (Beta), MySQL (Beta)",
    "Pluggable AI provider architecture — OpenAI, Anthropic, Google Gemini, xAI, Qwen",
    "Desktop app (macOS/Windows via Electron) and Docker self-hosting deployment modes",
    "SSH tunnel support for secure database connections",
    "Organization and team management with role-based access",
    "Billing integration via Stripe for hosted plans"
  ],
  "publicApiSurface": [
    "GET/POST /api/connection — List and create database connections",
    "GET /api/connection/[id] — Get connection details",
    "POST /api/connection/test — Test a database connection",
    "POST /api/connection/connect — Establish a connection pool",
    "POST /api/query — Execute SQL queries",
    "GET/POST /api/sql-console — SQL console session management",
    "POST /api/copilot/action — AI copilot SQL actions (generate/fix/explain)",
    "POST /api/chat — Database chatbot conversation",
    "GET/POST /api/chat/session — Chat session management",
    "GET /api/monitoring/summary — ClickHouse monitoring summary metrics",
    "GET /api/monitoring/query-logs — Query log history",
    "GET /api/monitoring/slow-queries — Slow query analysis",
    "GET /api/monitoring/error-queries — Error query tracking",
    "GET /api/monitoring/timeline — Query throughput timeline",
    "GET /api/privileges/users — ClickHouse user management",
    "GET /api/privileges/roles — ClickHouse role management",
    "GET /api/privileges/clusters — Cluster-level privilege operations",
    "POST /api/workspace — Workspace management",
    "GET /api/organization — Organization management",
    "GET /api/ai/usage — AI usage tracking"
  ]
